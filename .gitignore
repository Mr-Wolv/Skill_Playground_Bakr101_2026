# Python byte-code caches must never enter the skill store (they pollute
# mirror parity and are machine-specific). Audit/sync tooling compiles in
# memory; any __pycache__ created accidentally is ignored here.
__pycache__/
*.pyc
.deep_audit_report.json
# Timestamped sync/export backups are machine-local artifacts, never committed.
*.backup-*/
